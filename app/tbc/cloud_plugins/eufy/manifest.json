{
  "schema_version": 1,
  "key": "eufy",
  "label": "Eufy Security",
  "version": "1.3.0",
  "description": "Eufy-Security-Cloud-Konto und Kamerasuche via pyeufysecurity",
  "entrypoint": "plugin.py",
  "auth_type": "credentials",
  "identifier_label": "E-Mail-Adresse",
  "secret_label": "Passwort",
  "requires_host": false,
  "default_port": 443,
  "account_fields": [
    {
      "key": "email",
      "label": "E-Mail-Adresse",
      "type": "email",
      "required": true,
      "autocomplete": "username",
      "placeholder": "name@example.com"
    },
    {
      "key": "password",
      "label": "Passwort",
      "type": "password",
      "required": true,
      "autocomplete": "current-password"
    },
    {
      "key": "country",
      "label": "Ländercode",
      "type": "text",
      "required": true,
      "default": "DE",
      "placeholder": "DE",
      "help_text": "Zweistelliger ISO-Ländercode des Eufy-Kontos, z. B. DE, AT oder CH."
    },
    {
      "key": "verification_code",
      "label": "Eufy-Bestätigungscode (einmalig)",
      "type": "text",
      "autocomplete": "one-time-code",
      "placeholder": "Code aus der E-Mail",
      "help_text": "Leer lassen, um einen Code anzufordern. Nach erfolgreicher Bestätigung wird dieses Feld automatisch geleert.",
      "transient": true
    },
    {
      "key": "rtsp_username",
      "label": "Lokaler RTSP-Benutzername (optional)",
      "type": "text",
      "autocomplete": "off",
      "help_text": "Nur nötig, um Kameras mit in der Eufy-App aktiviertem NAS/RTSP als dauerhaften Stream zu übernehmen."
    },
    {
      "key": "rtsp_password",
      "label": "Lokales RTSP-Passwort (optional)",
      "type": "password",
      "autocomplete": "off"
    }
  ]
}
