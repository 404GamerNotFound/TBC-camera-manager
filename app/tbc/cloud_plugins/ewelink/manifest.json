{
  "schema_version": 1,
  "key": "ewelink",
  "label": "eWeLink (SONOFF)",
  "version": "1.0.0",
  "description": "SONOFF devices via the official eWeLink/CoolKit Open Platform cloud account",
  "entrypoint": "plugin.py",
  "auth_type": "credentials",
  "requires_host": false,
  "default_port": 443,
  "verification_support": "not_applicable",
  "account_fields": [
    {
      "key": "app_id",
      "label": "CoolKit App ID",
      "type": "text",
      "required": true,
      "help_text": "A free registration at dev.ewelink.cc provides an App ID and App Secret; your regular eWeLink app account is not sufficient on its own."
    },
    {
      "key": "app_secret",
      "label": "CoolKit App Secret",
      "type": "password",
      "required": true
    },
    {
      "key": "email",
      "label": "Email address",
      "type": "email",
      "required": true,
      "autocomplete": "username",
      "placeholder": "name@example.com"
    },
    {
      "key": "password",
      "label": "Password",
      "type": "password",
      "required": true,
      "autocomplete": "current-password"
    }
  ]
}
