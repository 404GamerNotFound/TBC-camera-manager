{
  "schema_version": 1,
  "key": "unifi_protect",
  "label": "UniFi Protect",
  "version": "1.0.0",
  "description": "Ubiquiti UniFi Protect Controller (local or via the ui.com cloud console) via uiprotect",
  "entrypoint": "plugin.py",
  "auth_type": "credentials",
  "identifier_label": "Username",
  "secret_label": "Password",
  "requires_host": true,
  "default_port": 443,
  "verification_support": "not_applicable",
  "account_fields": [
    {
      "key": "host",
      "label": "Host",
      "type": "text",
      "required": true,
      "placeholder": "192.168.1.1 or abc123.ui.com"
    },
    {
      "key": "port",
      "label": "Port",
      "type": "number",
      "default": 443,
      "min": 1,
      "max": 65535
    },
    {
      "key": "identifier",
      "label": "Username",
      "type": "text",
      "required": true,
      "autocomplete": "username"
    },
    {
      "key": "secret",
      "label": "Password",
      "type": "password",
      "required": true,
      "autocomplete": "current-password"
    },
    {
      "key": "verify_ssl",
      "label": "Verify SSL certificate",
      "type": "checkbox"
    }
  ]
}
